# Oracle Database Configuration
# Copy this file to .env and fill in your actual credentials

# Required: Oracle database username
ORACLE_USER=your_username_here

# Required: Oracle database DSN (Data Source Name)
# Example: hostname:port/service_name or (DESCRIPTION=...)
ORACLE_DSN=your_dsn_here

# Optional: Path to Oracle Instant Client library directory
# Only needed if Oracle Client libraries are not in your system PATH
ORACLE_LIB_DIR=/path/to/oracle/instant/client

# Optional: Oracle database password
# If not provided, will use keyring or prompt for password
ORACLE_PASSWORD=your_password_here
